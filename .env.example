# MAGI-Gem Configuration Example
# Copy this file to .env to configure local environment overrides.

# The system defaults to using Gemini CLI authentication.
# These variables are optional for advanced users or future direct API integration.

# GOOGLE_API_KEY=your_api_key_here
# MAGI_DEFAULT_MODEL=gemini-1.5-pro-latest
# MAGI_TIMEOUT=900
